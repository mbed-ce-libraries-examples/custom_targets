            "IRAM": {
                "access": {
                    "execute": false,
                    "read": true,
                    "write": true
                },
                "default": true,
                "size": 20480,
                "start": 536870912,
                "startup": false
            },
            "IROM": {
                "access": {
                    "execute": true,
                    "read": true,
                    "write": false
                },
                "default": true,
                "size": 65536,
                "start": 134217728,
                "startup": true
            }
        },
    },
}
